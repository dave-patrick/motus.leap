[Unit]
Description=Tube Manager
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/tube-manager
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/tube-manager/.venv/bin/uvicorn tube_manager.api:api --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
